{
  "expo": {
    "name": "Adventure List",
    "slug": "adventure-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gram",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.gram"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.example.gram"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Adventure List to access your photos so you can share adventures."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Adventure List to turn photo GPS into a place name."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
